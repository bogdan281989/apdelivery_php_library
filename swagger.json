      "BadRequest": {
        "description": "Невірний запит — відсутній обов'язковий параметр",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "success": false,
              "error": {
                "message": "Параметр city_uuid або city_id є обов'язковим",
                "code": "MISSING_PARAMETER"
              }
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Помилка автентифікації",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "missing": {
                "summary": "Ключ не надано",
                "value": {
                  "success": false,
                  "error": {
                    "message": "API ключ не надано",
                    "code": "API_KEY_MISSING"
                  }
                }
              },
              "invalid": {
                "summary": "Невірний ключ",
                "value": {
                  "success": false,
                  "error": {
                    "message": "Невірний API ключ",
                    "code": "API_KEY_INVALID"
                  }
                }
              },
              "inactive": {
                "summary": "Деактивований ключ",
                "value": {
                  "success": false,
                  "error": {
                    "message": "API ключ деактивовано",
                    "code": "API_KEY_INACTIVE"
                  }
                }
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "Доступ заборонено (IP, домен або HMAC)",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "examples": {
              "ip": {
                "summary": "IP не дозволено",
                "value": {
                  "success": false,
                  "error": {
                    "message": "IP адреса не дозволена",
                    "code": "IP_FORBIDDEN"
                  }
                }
              },
              "domain": {
                "summary": "Домен не дозволено",
                "value": {
                  "success": false,
                  "error": {
                    "message": "Домен не дозволений",
                    "code": "DOMAIN_FORBIDDEN"
                  }
                }
              },
              "hmac_missing": {
                "summary": "HMAC заголовки відсутні",
                "value": {
                  "success": false,
                  "error": {
                    "message": "HMAC підпис відсутній (потрібні заголовки X-Timestamp та X-Signature)",
                    "code": "HMAC_MISSING"
                  }
                }
              },
              "hmac_expired": {
                "summary": "Запит застарів",
                "value": {
                  "success": false,
                  "error": {
                    "message": "Запит застарів (X-Timestamp має бути в межах ±5 хвилин)",
                    "code": "HMAC_EXPIRED"
                  }
                }
              },
              "hmac_invalid": {
                "summary": "Невірний HMAC підпис",
                "value": {
                  "success": false,
                  "error": {
                    "message": "Невірний HMAC підпис",
                    "code": "HMAC_INVALID"
                  }
                }
              }
            }
          }
        }
      },
      "RateLimitExceeded": {
        "description": "Перевищено ліміт запитів",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            },
            "example": {
              "success": false,
              "error": {
                "message": "Перевищено ліміт запитів на добу",
